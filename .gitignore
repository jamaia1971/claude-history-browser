# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
