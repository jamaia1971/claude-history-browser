# but ignore a local copy too in case someone relocates it.
.claude_history_browser.json
*.log

# ── Secrets ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── OS cruft ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors / IDEs ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
